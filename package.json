{
  "name": "what-languages-have-i-used",
  "version": "1.0.0",
  "description": "Analyze language distribution across GitHub repos and local folders",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "build:server": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:push": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "drizzle-orm": "^0.30.0",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "fast-glob": "^3.3.2",
    "fastify": "^4.26.1",
    "gsap": "^3.12.5",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "sass": "^1.70.0",
    "superjson": "^2.2.1",
    "zod": "^3.22.4",
    "zustand": "^4.5.2",
    "@libsql/client": "^0.14.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.6",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}